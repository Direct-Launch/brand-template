{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Design tokens for {{CLIENT_NAME}}. Authoritative. Every $description contains the usage rule — read it before applying the value.",
  "colour": {
    "primary": {
      "$type": "color",
      "$value": "#000000",
      "$description": "TODO. Primary brand colour. State where it may and may not be used."
    },
    "secondary": {
      "$type": "color",
      "$value": "#000000",
      "$description": "TODO. Supporting colour and its role."
    },
    "accent": {
      "$type": "color",
      "$value": "#000000",
      "$description": "TODO. Accent colour. State the maximum share of a layout it may occupy."
    },
    "ink": {
      "$type": "color",
      "$value": "#111111",
      "$description": "Default body text colour on light backgrounds."
    },
    "paper": {
      "$type": "color",
      "$value": "#FFFFFF",
      "$description": "Default page background."
    },
    "muted": {
      "$type": "color",
      "$value": "#6B7280",
      "$description": "Secondary text. Must not be used for body copy below 16px."
    }
  },
  "font": {
    "heading": {
      "$type": "fontFamily",
      "$value": ["TODO", "Georgia", "serif"],
      "$description": "TODO. Headings only. Note licence in legal/licences.md."
    },
    "body": {
      "$type": "fontFamily",
      "$value": ["TODO", "system-ui", "sans-serif"],
      "$description": "TODO. Body copy, UI labels, forms."
    }
  },
  "fontSize": {
    "xs":   { "$type": "dimension", "$value": "0.75rem" },
    "sm":   { "$type": "dimension", "$value": "0.875rem" },
    "base": { "$type": "dimension", "$value": "1rem", "$description": "Minimum size for body copy. Never go below this for paragraphs." },
    "lg":   { "$type": "dimension", "$value": "1.125rem" },
    "xl":   { "$type": "dimension", "$value": "1.5rem" },
    "2xl":  { "$type": "dimension", "$value": "2rem" },
    "3xl":  { "$type": "dimension", "$value": "3rem" }
  },
  "fontWeight": {
    "regular": { "$type": "fontWeight", "$value": 400 },
    "medium":  { "$type": "fontWeight", "$value": 500 },
    "bold":    { "$type": "fontWeight", "$value": 700 }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "1rem" },
    "4": { "$type": "dimension", "$value": "1.5rem" },
    "5": { "$type": "dimension", "$value": "2rem" },
    "6": { "$type": "dimension", "$value": "3rem" },
    "7": { "$type": "dimension", "$value": "5rem" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0" },
    "sm":   { "$type": "dimension", "$value": "2px" },
    "md":   { "$type": "dimension", "$value": "6px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "150ms" },
      "base": { "$type": "duration", "$value": "250ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] }
    }
  }
}
